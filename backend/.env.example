PORT=3001
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/oauth-practice

SESSION_SECRET=change-this-to-a-long-random-string
JWT_SECRET=change-this-to-another-long-random-string
JWT_EXPIRES_IN=7d

# Google OAuth
# Get from: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# GitHub OAuth
# Get from: github.com → Settings → Developer settings → OAuth Apps → New OAuth App
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# Facebook OAuth
# Get from: developers.facebook.com → Create App → Facebook Login
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:3001/auth/facebook/callback

# Next.js frontend URL (where to redirect after OAuth success)
CLIENT_URL=http://localhost:3000
